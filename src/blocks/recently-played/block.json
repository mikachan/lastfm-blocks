{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "blocks-for-lastfm/recently-played-tracks",
	"version": "1.0.0",
	"title": "Recently Played Tracks",
	"category": "blocks-for-lastfm",
	"icon": "playlist-audio",
	"description": "Display your most recently played tracks scrobbled from Last.fm.",
	"keywords": [ "music", "sound" ],
	"attributes": {
		"textAlign": {
			"type": "string"
		},
		"username": {
			"type": "string"
		},
		"numberOfTracks": {
			"type": "string",
			"default": "1"
		},
		"showTrackArtwork": {
			"type": "boolean",
			"default": false
		},
		"imageStyle": {
			"type": "string",
			"default": "default"
		},
		"includeLinkToTrack": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"html": false,
		"align": true,
		"__experimentalBorder": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"color": {
			"gradients": true,
			"link": true,
			"__experimentalDefaultControls": {
				"background": true,
				"text": true
			}
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalDefaultControls": {
				"margin": false,
				"padding": false
			}
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalFontFamily": true,
			"__experimentalTextDecoration": true,
			"__experimentalFontStyle": true,
			"__experimentalFontWeight": true,
			"__experimentalLetterSpacing": true,
			"__experimentalTextTransform": true,
			"__experimentalWritingMode": true,
			"__experimentalDefaultControls": {
				"fontSize": true
			}
		},
		"shadow": true
	},
	"textdomain": "blocks-for-lastfm",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
